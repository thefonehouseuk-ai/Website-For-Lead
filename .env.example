# Google Apps Script web app URL (POST JSON body)
NEXT_PUBLIC_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/XXXX/exec
# Server-side preferred key (recommended to avoid exposing it publicly)
# GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/XXXX/exec

# Meta Pixel (optional — omit to disable tracking)
NEXT_PUBLIC_META_PIXEL_ID=

# Public site URL for Open Graph (set to your Vercel domain in production)
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# Optional: navbar Trustpilot / uSwitch link targets
# NEXT_PUBLIC_TRUSTPILOT_URL=https://uk.trustpilot.com/review/your-page
# NEXT_PUBLIC_USWITCH_URL=https://www.uswitch.com
